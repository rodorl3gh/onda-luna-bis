{
  "name": "onda-luna-bis",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "setup": "node scripts/setup-db.mjs",
    "dev:start": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev": "npm run setup && npm run dev:start",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm run dev --prefix client",
    "build": "npm run build --prefix client && npm run build --prefix server",
    "start": "node server/dist/index.js",
    "db:push": "npm run db:push --prefix server",
    "db:seed": "npm run db:seed --prefix server",
    "db:generate": "npm run db:generate --prefix server",
    "db:studio": "npm run db:studio --prefix server"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
